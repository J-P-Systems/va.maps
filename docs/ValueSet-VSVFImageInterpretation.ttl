# - resource -------------------------------------------------------------------

<http://va.gov/fhir/ValueSet/VSVFImageInterpretation> a fhir:ValueSet ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "VSVFImageInterpretation"] ; # 
  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>This value set includes codes based on the following rules:</p><ul><li>Include these codes as defined in <a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html\"><code>http://terminology.hl7.org/CodeSystem/v3-ObservationInterpretation</code></a><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td><td><b><a href=\"ConceptMap-CMVFImageInterpretation.html\">VF_ImageInterpretation</a></b></td></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-A\">A</a></td><td>Abnormal</td><td>The result or observation value is outside the reference range or expected norm (as defined for the respective test procedure).<br/><br/>\\[Note: Typically applies to non-numeric results.\\]</td><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-A\">A</a></td></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-E\">E</a></td><td>Equivocal</td><td>The test or procedure was successfully performed, but the results are borderline and can neither be declared positive / negative nor detected / not detected according to the current established criteria.</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-N\">N</a></td><td>Normal</td><td>The result or observation value is within the reference range or expected norm (as defined for the respective test procedure).<br/><br/>\\[Note: Applies to numeric or non-numeric results.\\]</td><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-N\">N</a></td></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-IND\">IND</a></td><td>Indeterminate</td><td>The specified component / analyte, organism or clinical sign could neither be declared positive / negative nor detected / not detected by the performed test or procedure.<br/><br/>*Usage Note:* For example, if the specimen was degraded, poorly processed, or was missing the required anatomic structures, then &quot;indeterminate&quot; (i.e. &quot;cannot be determined&quot;) is the appropriate response, not &quot;equivocal&quot;.</td><td/></tr></table></li><li>Include these codes as defined in <code>http://va.gov/terminology/vistaDefinedTerms/691.5-.03</code><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b><a href=\"ConceptMap-CMVFImageInterpretation.html\">VF_ImageInterpretation</a></b></td></tr><tr><td>A</td><td>ABNORMAL</td><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-A\">A</a></td></tr><tr><td>B</td><td>BORDERLINE</td><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-E\">E</a></td></tr><tr><td>N</td><td>NORMAL</td><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-N\">N</a></td></tr><tr><td>T</td><td>TECHNICALLY UNSATISFACTORY</td><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-IND\">IND</a><i>('Technically Unsatifactory' is used with EKG/ECG but not ECHO)</i></td></tr></table></li></ul></div>"
  ] ; # 
