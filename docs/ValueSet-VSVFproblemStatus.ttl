       ] )
     ] [
       fhir:system [ fhir:v "http://va.gov/terminology/vistaDefinedTerms/9000011-.12"^^xsd:anyURI ] ;
       fhir:concept ( [
         fhir:code [ fhir:v "A" ] ;
