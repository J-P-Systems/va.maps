     ] )
  ] ) ; # 
  fhir:description [ fhir:v "ValueSet for Terminology Maps VF_problemStatus"] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [ fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ] ;
