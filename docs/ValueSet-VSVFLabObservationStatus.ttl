  fhir:contact ( [
     fhir:name [ fhir:v "VA" ] ;
     fhir:telecom ( [
       fhir:system [ fhir:v "url" ] ;
       fhir:value [ fhir:v "https://www.va.gov" ]
     ] )
  ] ) ; # 
  fhir:description [ fhir:v "ValueSet for Terminology Maps VF_LabObservationStatus"] ; # 
  fhir:jurisdiction ( [
     fhir:coding ( [
       fhir:system [ fhir:v "urn:iso:std:iso:3166"^^xsd:anyURI ] ;
       fhir:code [ fhir:v "US" ] ;
       fhir:display [ fhir:v "United States of America" ]
     ] )
  ] ) ; # 
  fhir:compose [
     fhir:include ( [
       fhir:system [ fhir:v "http://hl7.org/fhir/observation-status"^^xsd:anyURI ] ;
       fhir:concept ( [
         fhir:code [ fhir:v "final" ] ;
         fhir:display [ fhir:v "Final" ]
       ] [
         fhir:code [ fhir:v "preliminary" ] ;
         fhir:display [ fhir:v "Preliminary" ]
       ] [
         fhir:code [ fhir:v "unknown" ] ;
         fhir:display [ fhir:v "Unknown" ]
       ] )
     ] [
       fhir:system [ fhir:v "urn:undefined"^^xsd:anyURI ] ;
       fhir:concept ( [
         fhir:code [ fhir:v "F" ] ;
         fhir:display [ fhir:v "FINAL REPORT" ]
       ] [
