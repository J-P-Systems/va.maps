VALENT">~</span><a href="http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-A">A</a></td></tr><tr><td>N</td><td>Normal</td><td><span title="EQUIVALENT">~</span><a href="http://terminology.hl7.org/3.1.0/CodeSystem-v3-ObservationInterpretation.html#v3-ObservationInterpretation-N">N</a></td></tr></table></li></ul></div>
