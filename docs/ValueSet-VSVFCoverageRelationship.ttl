<http://va.gov/fhir/ValueSet/VSVFCoverageRelationship> a fhir:ValueSet ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "VSVFCoverageRelationship"] ; # 
  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>This value set includes codes based on the following rules:</p><ul><li>Include these codes as defined in <a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html\"><code>http://terminology.hl7.org/CodeSystem/subscriber-relationship</code></a><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td><td><b><a href=\"ConceptMap-CMVFCoverageRelationship.html\">VF_CoverageRelationship</a></b></td></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-self\">self</a></td><td>Self</td><td>The Beneficiary is the Subscriber</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-spouse\">spouse</a></td><td>Spouse</td><td>The Beneficiary is a spouse or equivalent of the Subscriber</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-child\">child</a></td><td>Child</td><td>The Beneficiary is a child of the Subscriber</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-other\">other</a></td><td>Other</td><td>The Beneficiary has some other relationship the Subscriber</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-injured\">injured</a></td><td>Injured Party</td><td>The Beneficiary is covered under insurance of the subscriber due to an injury.</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-parent\">parent</a></td><td>Parent</td><td>The Beneficiary is a parent of the Subscriber</td><td/></tr><tr><td><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-common\">common</a></td><td>Common Law Spouse</td><td>The Beneficiary is a common law spouse or equivalent of the Subscriber</td><td/></tr></table></li><li>Include these codes as defined in <code>urn:undefined</code><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b><a href=\"ConceptMap-CMVFCoverageRelationship.html\">VF_CoverageRelationship</a></b></td></tr><tr><td>HIPAA_18_SELF</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-self\">self</a></td></tr><tr><td>HIPAA_01_SPOUSE</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-spouse\">spouse</a></td></tr><tr><td>HIPAA_19_CHILD</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-child\">child</a></td></tr><tr><td>HIPAA_20_EMPLOYEE</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-other\">other</a></td></tr><tr><td>HIPAA_39_ORGAN_DONOR</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-other\">other</a></td></tr><tr><td>HIPAA_41_INJURED_PLAINTIFF</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-injured\">injured</a></td></tr><tr><td>HIPAA_32_MOTHER</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-parent\">parent</a></td></tr><tr><td>HIPAA_33_FATHER</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-parent\">parent</a></td></tr><tr><td>HIPAA_29_SIGNIFICANT_OTHER</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-other\">other</a></td></tr><tr><td>HIPAA_53_LIFE_PARTNER</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-common\">common</a></td></tr><tr><td>HIPAA_G8_OTHER_RELATIONSHIP</td><td/><td><span title=\"EQUIVALENT\">~</span><a href=\"http://terminology.hl7.org/3.1.0/CodeSystem-subscriber-relationship.html#subscriber-relationship-other\">other</a></td></tr></table></li></ul></div>"
  ] ; # 
